# Multica WeChat Monitor Configuration
# Copy this file to .env and fill in your values: cp .env.example .env

# Target container name to monitor
CONTAINER_NAME=multica-backend-1

# Email address to watch for verification codes
TARGET_EMAIL=your-email@example.com

# Webhook URL to send verification codes to WeChat
WEBHOOK_URL=http://YOUR_HOST:8644/webhooks/verification-monitor

# Webhook secret for HMAC signature verification
WEBHOOK_SECRET=your-webhook-secret-here

# File to store sent verification codes (dedup)
SENT_FILE=/tmp/sent_codes.json
